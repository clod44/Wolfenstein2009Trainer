  <Comments>Info about this table:
</Comments>
  <LuaScript>function UDF1_CETrackBar_GoldChange(sender)
    UDF1.CELabel_Gold.Caption = "Gold (" .. sender.Position .. ")"
    getAddressList().getMemoryRecordByDescription("Gold Pointer").Value = sender.Position
end

function UDF1_CECheckbox_ManaChange(sender)
    getAddressList().getMemoryRecordByDescription("No Mana Cost").Active = sender.Checked
end

function UDF1_CECheckbox_MarketChange(sender)
    getAddressList().getMemoryRecordByDescription("Generous Market").Active = sender.Checked
end

function UDF1_CECheckbox_AmmoChange(sender)
    getAddressList().getMemoryRecordByDescription("Unlimited Ammo").Active = sender.Checked
end


function UDF1_CECheckbox_GodChange(sender)
    getAddressList().getMemoryRecordByDescription("God Mode").Active = sender.Checked
end


function UDF1_FormShow(sender)
    local goldRecord = getAddressList().getMemoryRecordByDescription("Gold Pointer")
    local currentGold = tonumber(goldRecord.Value) or 0

    -- Syncs the slider and the correct label on startup
    UDF1.CETrackBar_Gold.Position = currentGold
    UDF1.CELabel_Gold.Caption = "Gold (" .. currentGold .. ")"
end

function UDF1_CETimer1Timer(sender)
    local goldRecord = getAddressList().getMemoryRecordByDescription("Gold Pointer")
    if goldRecord == nil or goldRecord.Value == "??" then return end

    local currentGold = tonumber(goldRecord.Value) or 0
    -- Keeps the gold display updated live
    UDF1.CELabel_Gold.Caption = "Gold (" .. currentGold .. ")"
end

-- --- COMPILER START --- --
UDF1.show()

local janitorTimer = createTimer(getMainForm())
janitorTimer.Interval = 100
janitorTimer.OnTimer = function(t)
    -- BACKDOOR: Hold SHIFT while launching to keep CE visible for editing
    if not isKeyPressed(0x10) then
        getMainForm().hide()
        if CETrainer ~= nil then CETrainer.hide() end
    end

    if getProcessIDFromProcessName("Wolf2.exe") ~= nil then
        openProcess("Wolf2.exe")
        t.destroy()
    end
end


